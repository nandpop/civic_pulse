# Civic Pulse Configuration Template

# Server Port
PORT=5000

# SQLite Database File Path (Optional, defaults to database.sqlite in server folder)
DATABASE_URL=sqlite://./database.sqlite

# Google Maps API Key (Used by client)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google Cloud Credentials (For Vision API)
# Option A: Path to your Google Service Account Credentials JSON file
GOOGLE_APPLICATION_CREDENTIALS=relative/or/absolute/path/to/credentials.json

# Option B: Direct Service Account credentials (useful for server deployments)
# GCP_PROJECT_ID=your-gcp-project-id
# GCP_CLIENT_EMAIL=your-service-account-email@gcp-project.iam.gserviceaccount.com
# GCP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
